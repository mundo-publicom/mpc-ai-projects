# ---------------------------------------------------------------------------
# AI Voice Agent — environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# The app runs fully in "demo mode" (mock replies) with NONE of these set.
# ---------------------------------------------------------------------------

# --- AI model access (Vercel AI Gateway) ----------------------------------
# Primary path: a single gateway key routes all "provider/model" calls.
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Optional direct-provider fallback. If set (and no gateway key), the AI SDK
# will use Anthropic directly. Either key enables hasAI() -> live replies.
ANTHROPIC_API_KEY=

# --- Telephony: Twilio ------------------------------------------------------
# Programmable Voice — buy/route numbers, place & receive calls, media streams.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number (E.164) that answers inbound calls, e.g. +14155550123
TWILIO_PHONE_NUMBER=
# Twilio API key/secret pair (preferred over auth token for signing requests).
TWILIO_API_KEY=
TWILIO_API_SECRET=

# --- Speech-to-text: Deepgram ----------------------------------------------
# Streaming STT for the inbound audio leg (Nova-3 recommended for phone audio).
DEEPGRAM_API_KEY=

# --- Text-to-speech: ElevenLabs --------------------------------------------
# Low-latency streaming TTS for the agent's voice.
ELEVENLABS_API_KEY=
# Default voice used when an agent does not specify one.
ELEVENLABS_DEFAULT_VOICE_ID=

# --- App configuration ------------------------------------------------------
# Public base URL of THIS deployment. Used to build the telephony webhook and
# media-stream (wss://) URLs handed back to Twilio. In dev, use an ngrok/tunnel
# URL so Twilio can reach your machine.
PUBLIC_BASE_URL=http://localhost:3000

# Comma-separated list of jurisdictions that require two-party recording
# consent; the webhook plays the consent notice for calls to/from these.
TWO_PARTY_CONSENT_REGIONS=CA,WA,FL,PA,IL

# --- Datastore (optional; not required for the scaffold) --------------------
# Postgres connection string for persisting agents, calls, and transcripts.
DATABASE_URL=
