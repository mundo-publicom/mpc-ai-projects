# ---------------------------------------------------------------------------
# Faceless AI YouTube Generation — environment configuration
# Copy to .env.local and fill in. With NO keys set, the app runs in mock mode.
# ---------------------------------------------------------------------------

# --- AI (script generation via Vercel AI Gateway) --------------------------
# Preferred: a single gateway key routes all "provider/model" string calls.
AI_GATEWAY_API_KEY=
# Optional direct Anthropic key (used if the gateway key is absent).
ANTHROPIC_API_KEY=

# --- Text-to-speech (voiceover) --------------------------------------------
# ElevenLabs is the default TTS provider for narration.
ELEVENLABS_API_KEY=
# Default voice id used when a project has no configured VoiceProfile.
ELEVENLABS_DEFAULT_VOICE_ID=

# --- Image / B-roll generation ---------------------------------------------
# Generic image-provider key (e.g. fal.ai, Replicate, or a gateway image model).
IMAGE_PROVIDER_API_KEY=
FAL_API_KEY=

# --- Render / assembly provider --------------------------------------------
# Cloud render option (Shotstack). Leave blank to use the self-hosted ffmpeg worker.
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage
# Path to the ffmpeg binary for the self-hosted assembly worker.
FFMPEG_PATH=/usr/bin/ffmpeg

# --- YouTube Data API v3 (publishing) --------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback
# Long-lived refresh token obtained via the OAuth consent flow.
YOUTUBE_REFRESH_TOKEN=

# --- Storage & queue (production) ------------------------------------------
# Blob storage for generated audio/image/video assets.
BLOB_READ_WRITE_TOKEN=
# Redis connection for the background job queue.
REDIS_URL=

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
