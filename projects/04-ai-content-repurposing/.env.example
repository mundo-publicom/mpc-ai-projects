# ---------------------------------------------------------------------------
# AI Content Repurposing — environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- AI model access (required for live generation) ---
# Vercel AI Gateway key. Routes "provider/model" strings (see lib/ai.ts).
# Without this (and no ANTHROPIC_API_KEY), the app runs in graceful mock mode.
AI_GATEWAY_API_KEY=

# Optional: direct Anthropic key as a fallback provider path.
ANTHROPIC_API_KEY=

# --- Social scheduler integrations (optional; roadmap) ---
# Buffer: push approved outputs straight into a publishing queue.
BUFFER_ACCESS_TOKEN=
# Hypefury / Typefully style X-thread scheduling.
TYPEFULLY_API_KEY=
# Ayrshare unified social posting (multi-network).
AYRSHARE_API_KEY=

# --- Transcription (optional; ingest audio/video sources) ---
# Used to turn podcast/YouTube audio into source text before repurposing.
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# --- App config ---
# Public base URL (used for share links / callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000
