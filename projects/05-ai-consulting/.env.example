# ---------------------------------------------------------------------------
# AI Consulting — environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# The app runs fully with a deterministic mock when NO keys are set.
# ---------------------------------------------------------------------------

# --- AI (Vercel AI Gateway) ------------------------------------------------
# Primary: routes "provider/model" strings (e.g. anthropic/claude-sonnet-5)
# through the Vercel AI Gateway. When absent, /api/audit/generate returns a
# realistic mock audit instead of failing.
AI_GATEWAY_API_KEY=

# Optional fallback: direct Anthropic key (used only if the gateway key is unset).
ANTHROPIC_API_KEY=

# --- Payments (fixed-price audits + monthly retainers) ---------------------
# Stripe — used for audit-package checkout and retainer subscriptions.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Scheduling (discovery / readout calls) --------------------------------
# Cal.com or Calendly for booking intake + roadmap-readout sessions.
CAL_API_KEY=
NEXT_PUBLIC_SCHEDULING_URL=

# --- Document export / PDF -------------------------------------------------
# Optional service for rendering audits/proposals to branded PDF deliverables.
PDF_EXPORT_API_KEY=

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
