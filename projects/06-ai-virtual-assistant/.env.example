# ---------------------------------------------------------------------------
# AI Virtual Assistant — environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# The scaffold runs fully in mock mode with NONE of these set.
# ---------------------------------------------------------------------------

# --- AI model access (Vercel AI Gateway) ----------------------------------
# All model calls route through the Gateway using "provider/model" strings.
# Without this key the app degrades to a deterministic mock planner.
AI_GATEWAY_API_KEY=

# Optional: direct Anthropic key (only if not using the Gateway).
# ANTHROPIC_API_KEY=

# --- Google (Gmail + Google Calendar) --------------------------------------
# OAuth 2.0 client from the Google Cloud console. Scopes:
#   https://www.googleapis.com/auth/gmail.modify
#   https://www.googleapis.com/auth/calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# --- Slack -----------------------------------------------------------------
# Slack app credentials for reading/sending DMs and channel messages.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# --- App -------------------------------------------------------------------
# Base URL used to build OAuth redirects and links.
APP_BASE_URL=http://localhost:3000
