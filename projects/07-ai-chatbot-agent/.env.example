# ---------------------------------------------------------------------------
# AI Chatbot Agent — environment variables
#
# Every value is OPTIONAL for local development: with no keys set the app runs
# end-to-end using deterministic mock embeddings and a mock streamed answer, so
# the widget still streams and cites sources. Add keys to switch to real models.
# ---------------------------------------------------------------------------

# --- AI models (Vercel AI Gateway) -----------------------------------------
# A single gateway key unlocks chat (streamText) and embeddings (embedMany),
# billed through Vercel. Models are referenced as "provider/model" strings.
AI_GATEWAY_API_KEY=

# Alternatively, a direct provider key is also detected for the chat model.
ANTHROPIC_API_KEY=

# Chat + embedding model overrides (optional — sensible defaults in lib/ai.ts).
CHAT_MODEL=anthropic/claude-sonnet-5
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Vector store -----------------------------------------------------------
# The scaffold ships an in-memory vector store so it runs with zero setup.
# In production, point these at a managed vector DB. Leave blank to use memory.
VECTOR_DB=memory
# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=
# or Upstash Vector
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# --- Human handoff ----------------------------------------------------------
# When a conversation is escalated, notifications are posted to these channels.
SLACK_WEBHOOK_URL=
HANDOFF_EMAIL=

# --- App --------------------------------------------------------------------
# Comma-separated origins allowed to embed the widget (CORS). "*" for demos.
WIDGET_ALLOWED_ORIGINS=*
