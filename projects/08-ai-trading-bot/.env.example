# ---------------------------------------------------------------------------
# AI Trading Bot — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# The app runs fully with NO keys: signals + sentiment fall back to a
# deterministic mock, and backtests are pure-CPU. Keys unlock the real paths.
# ---------------------------------------------------------------------------

# --- AI (Vercel AI Gateway) ---
# Primary: routes "provider/model" strings (e.g. anthropic/claude-sonnet-5)
# through the Vercel AI Gateway. Get one at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Optional fallback: direct Anthropic key. Either this OR the gateway key
# flips hasAI() to true and enables generateObject sentiment analysis.
ANTHROPIC_API_KEY=

# --- Market data (optional; scaffold uses synthetic OHLC when absent) ---
# Any one of these can back a real market-data adapter (see TECHNICAL_SPEC.md).
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=

# --- News / sentiment source (optional) ---
NEWSAPI_API_KEY=

# --- Alpaca PAPER trading (optional; live is opt-in and off by default) ---
# Use PAPER keys from https://alpaca.markets — the base URL must be the paper
# endpoint. Live trading requires a separate, explicit opt-in flow.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Safety switch. Must be explicitly "true" to ever allow live routing.
# Leave unset/false for paper-only (the default and recommended mode).
ENABLE_LIVE_TRADING=false
