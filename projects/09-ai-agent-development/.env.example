# ---------------------------------------------------------------------------
# AI Agent Development Platform — environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# Vercel AI Gateway key. Model calls use plain "provider/model" strings routed
# through the gateway (e.g. "anthropic/claude-sonnet-5"). When this is absent
# the platform runs a deterministic MOCK agent loop so the demo works with zero
# configuration — you still get a full step-by-step trace, just canned outputs.
AI_GATEWAY_API_KEY=

# Optional: a direct Anthropic key is also accepted as a fallback signal that a
# model is available. Prefer AI_GATEWAY_API_KEY for gateway routing + spend caps.
# ANTHROPIC_API_KEY=
