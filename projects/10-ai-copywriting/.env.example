# ---------------------------------------------------------------------------
# AI Copywriting — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# Vercel AI Gateway key. All model calls route through the gateway using plain
# "provider/model" strings (e.g. "anthropic/claude-sonnet-5"). When this is
# absent the app still runs end-to-end using a deterministic mock generator.
AI_GATEWAY_API_KEY=

# Optional: a direct Anthropic key is also accepted as a fallback credential.
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Integrations (optional — not required for the demo to run)
# ---------------------------------------------------------------------------

# Google Ads API (export ad copy as RSA assets).
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=

# Meta Marketing API (push ad creative to Ads Manager).
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# ESP for email copy (choose one; used to sync sequences).
# SENDGRID_API_KEY=
# CUSTOMERIO_API_KEY=
# KLAVIYO_API_KEY=
