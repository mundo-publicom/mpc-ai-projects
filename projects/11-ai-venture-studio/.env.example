# --- AI access -------------------------------------------------------------
# Vercel AI Gateway key. Model calls use plain "provider/model" strings routed
# through the gateway (e.g. "anthropic/claude-sonnet-5"). When this is absent,
# the /api/validate route serves realistic mock validation reports so the whole
# studio is demoable with zero configuration.
AI_GATEWAY_API_KEY=

# Optional: direct Anthropic key. Either variable satisfies hasAI().
# ANTHROPIC_API_KEY=

# --- Optional integrations (future) ----------------------------------------
# Market-data / TAM enrichment provider key (see docs/TECHNICAL_SPEC.md).
# MARKET_DATA_API_KEY=
# Product analytics write key for funnel + sprint-throughput events.
# ANALYTICS_WRITE_KEY=
