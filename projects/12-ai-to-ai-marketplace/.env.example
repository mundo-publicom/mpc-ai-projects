# ---------------------------------------------------------------------------
# Agora — AI-to-AI Marketplace — environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# The app runs fully in "demo mode" (deterministic negotiation + settlement)
# with NONE of these set.
# ---------------------------------------------------------------------------

# --- AI model access (Vercel AI Gateway) ----------------------------------
# Primary path: a single gateway key routes all "provider/model" calls used by
# the negotiation engine (buyer + seller agents) and capability matching.
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Optional direct-provider fallback. If set (and no gateway key), the AI SDK
# uses Anthropic directly. Either key enables hasAI() -> live negotiation.
ANTHROPIC_API_KEY=

# --- Settlement / payment rail ---------------------------------------------
# Agent transactions settle in stablecoins. The scaffold's ledger is in-memory;
# wiring a rail below turns escrow release into real value movement.

# Circle (USDC) programmable wallets + payouts.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# The platform's fee-collection wallet id (where the take-rate accrues).
PLATFORM_FEE_WALLET_ID=

# x402 / HTTP 402 machine-payment facilitator (per-call agent payments).
# https://www.x402.org
X402_FACILITATOR_URL=
X402_CHAIN=base-sepolia

# Optional card-rail fallback for fiat top-ups of agent wallets.
STRIPE_SECRET_KEY=

# --- Platform economics -----------------------------------------------------
# Take-rate applied to every settled transaction, in basis points.
# 250 = 2.5%. Overrides the default in lib/ledger.ts when set.
PLATFORM_TAKE_RATE_BPS=250

# --- Agent identity / trust -------------------------------------------------
# Signing key the platform uses to attest verified agents (DID method issuer).
PLATFORM_DID_SIGNING_KEY=
# Optional KYB provider for verifying seller operators before payout.
KYB_PROVIDER_API_KEY=

# --- Datastore (optional; not required for the scaffold) --------------------
# Postgres connection string for the registry, ledger, and reputation store.
DATABASE_URL=

# --- App configuration ------------------------------------------------------
# Public base URL of THIS deployment (used to build A2A/MCP callback URLs).
PUBLIC_BASE_URL=http://localhost:3000
