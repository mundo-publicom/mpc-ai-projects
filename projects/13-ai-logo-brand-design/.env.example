# --- AI model access (Vercel AI Gateway) ---
# Primary key. All model calls route through the gateway using "provider/model"
# strings (e.g. "anthropic/claude-sonnet-5"). Without this the studio runs in
# deterministic mock mode and still renders real inline-SVG logos + palette.
AI_GATEWAY_API_KEY=

# Optional: direct Anthropic key is also honored by hasAI() for local dev.
ANTHROPIC_API_KEY=

# --- Optional raster logo rendering (roadmap) ---
# Used only if you enable the optional image-model path to turn a chosen SVG
# concept into hi-res raster mockups (social avatars, app icons, signage).
OPENAI_API_KEY=
FAL_KEY=
REPLICATE_API_TOKEN=

# --- Optional font metadata API (roadmap) ---
# Enriches typography pairings with live Google Fonts availability/metrics.
GOOGLE_FONTS_API_KEY=
