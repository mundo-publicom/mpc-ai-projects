# ---------------------------------------------------------------------------
# Managed AI Cybersecurity — environment configuration
# Copy to .env.local and fill in. The demo runs with ZERO keys (mock triage +
# deterministic posture scoring); keys unlock the real AI triage engine and
# live signal ingestion.
# ---------------------------------------------------------------------------

# --- AI (required for real triage; omit to use the deterministic mock) ------
# Vercel AI Gateway key. Model calls use "provider/model" strings routed
# through the gateway (e.g. anthropic/claude-sonnet-5).
AI_GATEWAY_API_KEY=

# Alternatively, a direct Anthropic key also enables AI mode.
ANTHROPIC_API_KEY=

# --- Signal ingestion: SIEM feeds -------------------------------------------
# Splunk HTTP Event Collector (or equivalent SIEM) for pulling/pushing events.
SIEM_API_URL=
SIEM_API_TOKEN=

# Microsoft Sentinel / Log Analytics (optional alternative SIEM).
SENTINEL_WORKSPACE_ID=
SENTINEL_SHARED_KEY=

# --- Signal ingestion: EDR feeds --------------------------------------------
# CrowdStrike Falcon API (OAuth2 client credentials).
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=

# SentinelOne management console API token.
SENTINELONE_API_TOKEN=
SENTINELONE_CONSOLE_URL=

# Microsoft Defender for Endpoint (optional).
DEFENDER_TENANT_ID=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=

# --- Identity provider audit logs -------------------------------------------
OKTA_ORG_URL=
OKTA_API_TOKEN=

# --- Alerting & ticketing destinations --------------------------------------
# Slack incoming webhook for high-severity alert notifications.
SLACK_WEBHOOK_URL=

# Jira / ServiceNow for auto-created remediation tickets.
TICKETING_API_URL=
TICKETING_API_TOKEN=

# --- Platform ---------------------------------------------------------------
# Public base URL of this deployment (used in notification deep-links).
APP_BASE_URL=http://localhost:3000
